#!/bin/sh
# Auto-installed pre-commit hook (2026-04-27, updated 2026-04-30)
# Mirrors .github/workflows/validate_dd_meta.yml strict gate locally —
# blocks commits that would fail CI for dd-meta / id-meta JSON validation.
#
# Modes:
#   - Default (staged-only): when only DD/ID files staged, lint just those
#     files (efficient, single-file commits don't slow down).
#   - Full-sweep: when validator script itself is staged (rule upgrade),
#     lint ALL DD/ID files in repo to force historical-debt cleanup at
#     rule-upgrade time. This prevents the "Boomer Travel" pattern where
#     pre-existing files quietly violate new rules.
#
# Triggers only when staged files touch docs/dd/DD_*.html, docs/id/ID_*.html,
# or the validators themselves (so unrelated commits aren't slowed).
#
# To bypass in emergency: git commit --no-verify

set -e

# .nojekyll guard: this site is hand-written static HTML+JSON+JS, NEVER uses
# Jekyll. Removing docs/.nojekyll re-enables Jekyll and Pages builds will
# timeout / error (historical incident 2026-05-26: 1609-file docs/ choked
# Jekyll, multiple consecutive Pages builds errored before .nojekyll added).
# Always check; cost is one stat() call.
if [ ! -f docs/.nojekyll ]; then
  echo ""
  echo "❌ docs/.nojekyll is missing — commit blocked."
  echo ""
  echo "   This file MUST exist to prevent GitHub Pages from running Jekyll"
  echo "   on docs/. Without it, Pages re-enables Jekyll, builds slow down"
  echo "   as docs/ grows, and eventually time out (2026-05-26 incident)."
  echo ""
  echo "   Fix: 'touch docs/.nojekyll && git add docs/.nojekyll', then retry."
  echo "   Bypass: --no-verify (only if you truly want Jekyll, which you don't)."
  exit 1
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_DEL=$(git diff --cached --name-only --diff-filter=D)

# Block deletion of docs/.nojekyll
if echo "$STAGED_DEL" | grep -qx 'docs/\.nojekyll'; then
  echo ""
  echo "❌ Refusing to delete docs/.nojekyll — commit blocked."
  echo ""
  echo "   This file disables Jekyll on Pages. Removing it will cause Pages"
  echo "   builds to time out as docs/ grows. See 2026-05-26 incident."
  echo ""
  echo "   If you truly need Jekyll, bypass with --no-verify, but the site"
  echo "   architecture (hand-written HTML + JSON + JS) does not need it."
  exit 1
fi

STAGED_DD=$(echo "$STAGED" | grep -E '^docs/dd/DD_.*\.html$' || true)
STAGED_ID=$(echo "$STAGED" | grep -E '^docs/id/ID_.*\.html$' || true)
STAGED_CACHE=$(echo "$STAGED" | grep -E '^docs/cache/(fundamentals|prices)-(us|tw|jp)\.json$' || true)
STAGED_SC=$(echo "$STAGED" | grep -E '^docs/supply-chain/data/.*\.json$' | grep -v 'dd_links\.json$' || true)
DD_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_dd_meta\.py$' || true)
ID_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_id_meta\.py$' || true)
CACHE_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_cache_schema\.py$' || true)
SC_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_supply_chain_meta\.py$' || true)

# Size-floor gate operates on ADDED files only (diff-filter=A). A fresh report is
# always a new DD_/DCA_<date>.html (an Add); metadata patches to legacy reports are
# Modifies and must NOT be size-gated (471 DD files span 33-130KB — many legacy
# ones are organically <80KB and would false-block). New reports must clear floor.
ADDED=$(git diff --cached --name-only --diff-filter=A)
ADDED_DD=$(echo "$ADDED" | grep -E '^docs/dd/DD_.*\.html$' || true)
ADDED_DCA=$(echo "$ADDED" | grep -E '^docs/dca/DCA_.*\.html$' || true)

# Bail early if nothing relevant in scope
if [ -z "$STAGED_DD" ] && [ -z "$STAGED_ID" ] && [ -z "$STAGED_CACHE" ] && [ -z "$STAGED_SC" ] && \
   [ -z "$DD_VALIDATOR_CHANGED" ] && [ -z "$ID_VALIDATOR_CHANGED" ] && [ -z "$CACHE_VALIDATOR_CHANGED" ] && \
   [ -z "$SC_VALIDATOR_CHANGED" ] && [ -z "$ADDED_DCA" ]; then
  exit 0
fi

FAIL=0

# ---- DD/DCA size-floor gate (added files only) -------------------------------
# Hard floor = authoritative size memory; soft warn = skill target. Floors:
#   v13 DD (merged DD+DCA decision layer): 110KB hard / 125KB soft
#   legacy v12 DD:                          80KB hard /  90KB soft
#   legacy DCA (retired, dormant gate):     50KB hard /  55KB soft
# Real v12.7 output is DD ~105-108KB; v13 folds in the decision layer (~+25-35KB).
# The hard floor leaves margin and only fires on genuinely thin new reports
# (the "偷懶" pattern). NOT a byte target — anti-灌水 rule still governs upward.
# Bypass a legitimately-lean report with: git commit --no-verify
check_report_size() {  # $1=file  $2=hardBytes  $3=warnBytes  $4=label
  _b=$(wc -c < "$1" 2>/dev/null || echo 0)
  if [ "$_b" -lt "$2" ]; then
    echo "❌ $4 $(basename "$1"): ${_b}B < ${2}B floor — too thin (depth gate), commit blocked."
    return 1
  elif [ "$_b" -lt "$3" ]; then
    echo "⚠️  $4 $(basename "$1"): ${_b}B < ${3}B skill target — thin but allowed."
  fi
  return 0
}
if [ -n "$ADDED_DD" ] || [ -n "$ADDED_DCA" ]; then
  echo "→ pre-commit: checking new DD/DCA size floors (added files only)"
  # DD floor is schema-aware: v13 merged report ≥110KB, legacy v12 DD ≥80KB.
  for f in $ADDED_DD; do
    if grep -qE '"schema"[[:space:]]*:[[:space:]]*"v1[34]' "$f" 2>/dev/null; then
      check_report_size "$f" 110000 125000 "DD" || FAIL=1
    else
      check_report_size "$f" 80000 90000 "DD" || FAIL=1
    fi
  done
  for f in $ADDED_DCA; do check_report_size "$f" 50000 55000 "DCA" || FAIL=1; done
  if [ "$FAIL" -ne 0 ]; then
    echo "   A new report under the floor usually means a skipped section or"
    echo "   bullet-only padding. Deepen it (sourced numbers, not 灌水), or"
    echo "   --no-verify if it is genuinely a lean-but-complete report."
  fi
fi
# ------------------------------------------------------------------------------

# DD path: validator changed → full sweep; else staged only
TARGETS_DD=""
MODE_DD=""
if [ -n "$DD_VALIDATOR_CHANGED" ]; then
  TARGETS_DD=$(find docs/dd -maxdepth 1 -name 'DD_*.html' 2>/dev/null)
  MODE_DD="full sweep (validator changed — clearing historical debt)"
elif [ -n "$STAGED_DD" ]; then
  TARGETS_DD="$STAGED_DD"
  MODE_DD="staged only"
fi

if [ -n "$TARGETS_DD" ]; then
  echo "→ pre-commit: validating dd-meta — $MODE_DD"
  if ! python3 scripts/validate_dd_meta.py $TARGETS_DD > /tmp/_dd_validate.log 2>&1; then
    echo ""
    echo "❌ dd-meta validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_dd_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

# ID path: validator changed → full sweep; else staged only
TARGETS_ID=""
MODE_ID=""
if [ -n "$ID_VALIDATOR_CHANGED" ]; then
  TARGETS_ID=$(find docs/id -maxdepth 1 -name 'ID_*.html' 2>/dev/null)
  MODE_ID="full sweep (validator changed — clearing historical debt)"
elif [ -n "$STAGED_ID" ]; then
  TARGETS_ID="$STAGED_ID"
  MODE_ID="staged only"
fi

if [ -n "$TARGETS_ID" ]; then
  echo "→ pre-commit: validating id-meta — $MODE_ID"
  if ! python3 scripts/validate_id_meta.py $TARGETS_ID > /tmp/_id_validate.log 2>&1; then
    echo ""
    echo "❌ id-meta validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_id_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

# Cache schema path: validator changed → full sweep; else staged only
TARGETS_CACHE=""
MODE_CACHE=""
if [ -n "$CACHE_VALIDATOR_CHANGED" ]; then
  # Full sweep: re-validate all cache files when validator script itself changes
  MODE_CACHE="full sweep (validator changed)"
  # validate_cache_schema.py with no args validates everything in docs/cache/
elif [ -n "$STAGED_CACHE" ]; then
  MODE_CACHE="staged only"
fi

if [ -n "$TARGETS_CACHE" ] || [ -n "$STAGED_CACHE" ] || [ -n "$CACHE_VALIDATOR_CHANGED" ]; then
  echo "→ pre-commit: validating cache schema — $MODE_CACHE"
  if [ -n "$CACHE_VALIDATOR_CHANGED" ]; then
    VALIDATE_CMD="python3 scripts/validate_cache_schema.py"
  else
    VALIDATE_CMD="python3 scripts/validate_cache_schema.py --staged"
  fi
  if ! $VALIDATE_CMD > /tmp/_cache_validate.log 2>&1; then
    echo ""
    echo "❌ cache schema validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_cache_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

# Supply-chain path: validator changed → full sweep; else staged only
TARGETS_SC=""
MODE_SC=""
if [ -n "$SC_VALIDATOR_CHANGED" ]; then
  TARGETS_SC=$(find docs/supply-chain/data -maxdepth 1 -name '*.json' ! -name 'dd_links.json' 2>/dev/null)
  MODE_SC="full sweep (validator changed — clearing historical debt)"
elif [ -n "$STAGED_SC" ]; then
  TARGETS_SC="$STAGED_SC"
  MODE_SC="staged only"
fi

if [ -n "$TARGETS_SC" ]; then
  echo "→ pre-commit: validating supply-chain schema — $MODE_SC"
  if ! python3 scripts/validate_supply_chain_meta.py $TARGETS_SC > /tmp/_sc_validate.log 2>&1; then
    echo ""
    echo "❌ supply-chain schema validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_sc_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

# Supply-chain hub rollup: when map data changed AND all validation passed,
# regenerate the cross-map 💎/🐘/🔒 synthesis between the TIERS_AUTO markers in
# docs/supply-chain/index.html and stage it — so /supply-chain/ can never go
# stale relative to the maps, regardless of whether they were edited via the
# cartographer skill or by hand. (Only rewrites between markers; manual hub
# edits like the coverage matrix are preserved.)
if [ -n "$STAGED_SC" ] && [ "$FAIL" -eq 0 ]; then
  echo "→ pre-commit: rebuilding hub tiers rollup (supply-chain data changed)"
  if python3 scripts/build_supply_chain_tiers.py > /tmp/_sc_tiers.log 2>&1; then
    git add docs/supply-chain/index.html
  else
    echo ""
    echo "❌ build_supply_chain_tiers.py FAILED — commit blocked."
    tail -15 /tmp/_sc_tiers.log | sed 's/^/   /'
    FAIL=1
  fi
fi

if [ "$FAIL" -ne 0 ]; then
  exit 1
fi

echo "✅ pre-commit: validation passed"
exit 0
