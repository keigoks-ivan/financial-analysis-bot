#!/bin/sh
# Auto-installed pre-commit hook (2026-04-27, updated 2026-04-30)
# Mirrors .github/workflows/validate_dd_meta.yml strict gate locally —
# blocks commits that would fail CI for dd-meta / id-meta JSON validation.
#
# Modes:
#   - Default (staged-only): when only DD/ID files staged, lint just those
#     files (efficient, single-file commits don't slow down).
#   - Full-sweep: when validator script itself is staged (rule upgrade),
#     lint ALL DD/ID files in repo to force historical-debt cleanup at
#     rule-upgrade time. This prevents the "Boomer Travel" pattern where
#     pre-existing files quietly violate new rules.
#
# Triggers only when staged files touch docs/dd/DD_*.html, docs/id/ID_*.html,
# or the validators themselves (so unrelated commits aren't slowed).
#
# To bypass in emergency: git commit --no-verify

set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

STAGED_DD=$(echo "$STAGED" | grep -E '^docs/dd/DD_.*\.html$' || true)
STAGED_ID=$(echo "$STAGED" | grep -E '^docs/id/ID_.*\.html$' || true)
STAGED_CACHE=$(echo "$STAGED" | grep -E '^docs/cache/(fundamentals|prices)-(us|tw|jp)\.json$' || true)
STAGED_SC=$(echo "$STAGED" | grep -E '^docs/supply-chain/data/.*\.json$' | grep -v 'dd_links\.json$' || true)
DD_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_dd_meta\.py$' || true)
ID_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_id_meta\.py$' || true)
CACHE_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_cache_schema\.py$' || true)
SC_VALIDATOR_CHANGED=$(echo "$STAGED" | grep -E '^scripts/validate_supply_chain_meta\.py$' || true)

# Bail early if nothing relevant in scope
if [ -z "$STAGED_DD" ] && [ -z "$STAGED_ID" ] && [ -z "$STAGED_CACHE" ] && [ -z "$STAGED_SC" ] && \
   [ -z "$DD_VALIDATOR_CHANGED" ] && [ -z "$ID_VALIDATOR_CHANGED" ] && [ -z "$CACHE_VALIDATOR_CHANGED" ] && \
   [ -z "$SC_VALIDATOR_CHANGED" ]; then
  exit 0
fi

FAIL=0

# DD path: validator changed → full sweep; else staged only
TARGETS_DD=""
MODE_DD=""
if [ -n "$DD_VALIDATOR_CHANGED" ]; then
  TARGETS_DD=$(find docs/dd -maxdepth 1 -name 'DD_*.html' 2>/dev/null)
  MODE_DD="full sweep (validator changed — clearing historical debt)"
elif [ -n "$STAGED_DD" ]; then
  TARGETS_DD="$STAGED_DD"
  MODE_DD="staged only"
fi

if [ -n "$TARGETS_DD" ]; then
  echo "→ pre-commit: validating dd-meta — $MODE_DD"
  if ! python3 scripts/validate_dd_meta.py $TARGETS_DD > /tmp/_dd_validate.log 2>&1; then
    echo ""
    echo "❌ dd-meta validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_dd_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

# ID path: validator changed → full sweep; else staged only
TARGETS_ID=""
MODE_ID=""
if [ -n "$ID_VALIDATOR_CHANGED" ]; then
  TARGETS_ID=$(find docs/id -maxdepth 1 -name 'ID_*.html' 2>/dev/null)
  MODE_ID="full sweep (validator changed — clearing historical debt)"
elif [ -n "$STAGED_ID" ]; then
  TARGETS_ID="$STAGED_ID"
  MODE_ID="staged only"
fi

if [ -n "$TARGETS_ID" ]; then
  echo "→ pre-commit: validating id-meta — $MODE_ID"
  if ! python3 scripts/validate_id_meta.py $TARGETS_ID > /tmp/_id_validate.log 2>&1; then
    echo ""
    echo "❌ id-meta validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_id_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

# Cache schema path: validator changed → full sweep; else staged only
TARGETS_CACHE=""
MODE_CACHE=""
if [ -n "$CACHE_VALIDATOR_CHANGED" ]; then
  # Full sweep: re-validate all cache files when validator script itself changes
  MODE_CACHE="full sweep (validator changed)"
  # validate_cache_schema.py with no args validates everything in docs/cache/
elif [ -n "$STAGED_CACHE" ]; then
  MODE_CACHE="staged only"
fi

if [ -n "$TARGETS_CACHE" ] || [ -n "$STAGED_CACHE" ] || [ -n "$CACHE_VALIDATOR_CHANGED" ]; then
  echo "→ pre-commit: validating cache schema — $MODE_CACHE"
  if [ -n "$CACHE_VALIDATOR_CHANGED" ]; then
    VALIDATE_CMD="python3 scripts/validate_cache_schema.py"
  else
    VALIDATE_CMD="python3 scripts/validate_cache_schema.py --staged"
  fi
  if ! $VALIDATE_CMD > /tmp/_cache_validate.log 2>&1; then
    echo ""
    echo "❌ cache schema validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_cache_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

# Supply-chain path: validator changed → full sweep; else staged only
TARGETS_SC=""
MODE_SC=""
if [ -n "$SC_VALIDATOR_CHANGED" ]; then
  TARGETS_SC=$(find docs/supply-chain/data -maxdepth 1 -name '*.json' ! -name 'dd_links.json' 2>/dev/null)
  MODE_SC="full sweep (validator changed — clearing historical debt)"
elif [ -n "$STAGED_SC" ]; then
  TARGETS_SC="$STAGED_SC"
  MODE_SC="staged only"
fi

if [ -n "$TARGETS_SC" ]; then
  echo "→ pre-commit: validating supply-chain schema — $MODE_SC"
  if ! python3 scripts/validate_supply_chain_meta.py $TARGETS_SC > /tmp/_sc_validate.log 2>&1; then
    echo ""
    echo "❌ supply-chain schema validation FAILED — commit blocked."
    echo "   Tail of validator output:"
    tail -25 /tmp/_sc_validate.log | sed 's/^/   /'
    echo ""
    echo "   Fix locally then retry. Bypass with --no-verify only if intentional."
    FAIL=1
  fi
fi

if [ "$FAIL" -ne 0 ]; then
  exit 1
fi

echo "✅ pre-commit: validation passed"
exit 0
